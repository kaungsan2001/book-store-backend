// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
  AUTHOR
}

enum UserStatus {
  ACTIVE
  FROZEN
  BANNED
}

model User {
  id              String     @id @default(cuid(2))
  name            String?    @db.VarChar(100)
  email           String     @unique @db.VarChar(255)
  password        String     @db.VarChar(255)
  avatarUrl       String?    @db.Text()
  role            Role       @default(USER)
  refreshToken    String?    @db.VarChar(255)
  status          UserStatus @default(ACTIVE)
  lastLogin       DateTime?
  errorLoginCount Int        @default(0) @db.SmallInt

  articles Article[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

model Otp {
  id             String    @id @default(cuid(2))
  email          String    @unique @db.VarChar(255)
  code           String
  token          String    @db.VarChar(255)
  verifyToken    String?   @db.VarChar(255)
  sentCount      Int       @default(0) @db.SmallInt
  invalidCount   Int       @default(0) @db.SmallInt
  lastSentAt     DateTime
  lastVerifiedAt DateTime?
  expiresAt      DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

model Category {
  id          String    @id @default(cuid(2))
  name        String    @unique @db.VarChar(255)
  description String?   @db.Text()
  products    Product[]
  articles    Article[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

model Product {
  id            String         @id @default(cuid(2))
  name          String         @db.VarChar(255)
  description   String?        @db.Text()
  price         Int
  discount      Int?           @default(0)
  inventory     Int
  categoryId    String
  category      Category       @relation(fields: [categoryId], references: [id])
  productImages ProductImage[]
  productTag    ProductTag[]

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([name])
}

model ProductImage {
  id        String  @id @default(cuid(2))
  imageUrl  String  @db.Text()
  productId String
  product   Product @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductTag {
  id       String    @id @default(cuid(2))
  name     String    @unique @db.VarChar(50)
  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

model Article {
  id         String       @id @default(cuid(2))
  title      String       @db.VarChar(255)
  content    String       @db.Text()
  imageUrl   String       @db.Text()
  imageId    String
  tags       ArticleTag[]
  authorId   String
  author     User         @relation(fields: [authorId], references: [id])
  category   Category     @relation(fields: [categoryId], references: [id])
  categoryId String

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model ArticleTag {
  id       String    @id @default(cuid(2))
  name     String    @unique @db.VarChar(50)
  articles Article[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

// Store image public_ids and delete them using a midnight cron job. 1 ->30
model ToDeleteImage {
  id        String   @id @default(cuid(2))
  imageId   String   @unique
  attempts  Int?     @db.SmallInt
  deletedAt DateTime @default(now())

  @@index([imageId])
}
